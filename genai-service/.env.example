# GenAI Service Configuration
LLM_PROVIDER=azure
# For local non-Docker runs, set AZURE_LLM_API_KEY in genai-service/.env.
# Docker Compose reads this from genai-service/.secrets/azure_llm_api_key instead.
AZURE_LLM_BASE_URL=https://continous-vacation.cognitiveservices.azure.com/
AZURE_LLM_API_VERSION=2024-12-01-preview
MODEL_NAME=gpt-5-nano
TEMPERATURE=0.7
MAX_TOKENS=8000

# Local LLM Configuration
LOCAL_LLM_API_KEY=ollama
LOCAL_LLM_BASE_URL=http://localhost:11434/v1

# Service Configuration
LOG_LEVEL=DEBUG
