+            className={cn("text-destructive", "hover:text-destructive")}
+          />
+          <span className={cn("text-destructive", "hover:text-destructive")}>
+            {isLoggingOut ? "Logging out..." : "Logout"}
+          </span>
+        </DropdownMenuItem>
+      </DropdownMenuContent>
+    </DropdownMenu>
+  );
+};
