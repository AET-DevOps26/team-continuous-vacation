+    i18nKey: "table.filter.operator.nina",
+    defaultLabel: "Not includes in an array (case sensitive)",
+  },
+  contains: {
+    i18nKey: "table.filter.operator.contains",
+    defaultLabel: "Contains",
+  },
+  ncontains: {
+    i18nKey: "table.filter.operator.ncontains",
