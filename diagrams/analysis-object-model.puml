@startuml analysis-object-model
title TripTailor - Analysis Object Model

class Trip {
  destination
  dates
  vibe
  + view()
  + create()
}

class Day {
  date
  + view()
}

class Activity {
  title
  description
  duration
  timeBlock
  tags
  + view()
  + regenerate()
}

class User {
  preferences
  + createTrip()
  + editActivity()
}

class GenAIService {
  + generateItinerary()
  + regenerateActivity()
}

Trip "1" -- "*" Day
Day "1" -- "*" Activity

User ..> Trip : creates/views
User ..> Activity : edits/regenerates

Trip ..> GenAIService : uses
Activity ..> GenAIService : uses

@enduml